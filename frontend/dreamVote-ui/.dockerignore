# Dependencies and build output - both are recreated inside the Docker build
# stage. Including the host's node_modules would slow the build and risk
# baking platform-specific binaries (e.g. macOS arm64 esbuild) into a Linux image.
node_modules/
dist/

# Vite cache
.vite/

# Local env files - never bake secrets or env-specific URLs into images.
# Runtime config is injected via the entrypoint script at container startup.
.env
.env.*
!.env.example

# IDE and OS metadata
.idea/
.vscode/
*.iml
.DS_Store

# Git history
.git/
.gitignore

# Docker assets - read by docker build, not needed inside the image
Dockerfile
.dockerignore

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
